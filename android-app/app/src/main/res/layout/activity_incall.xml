<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:padding="24dp">

    <!-- Top Section: Caller Info -->
    <LinearLayout
        android:id="@+id/caller_info_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- TeleSMS Logo/Icon -->
        <ImageView
            android:id="@+id/iv_caller_avatar"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/circle_bg_blue"
            android:contentDescription="Caller"
            android:padding="20dp"
            android:src="@android:drawable/sym_action_call"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TeleSMS Call"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_phone_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="#B0B0B0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Connecting..."
            android:textColor="#4CAF50"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_recording_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="● REC"
            android:textColor="#FF4444"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Incoming Call Controls (Answer + Reject) -->
    <LinearLayout
        android:id="@+id/incoming_call_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Reject Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_reject"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/circle_bg_red"
                android:contentDescription="Reject"
                android:padding="18dp"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Decline"
                android:textColor="#B0B0B0"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="80dp"
            android:layout_height="1dp" />

        <!-- Answer Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_answer"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/circle_bg_green"
                android:contentDescription="Answer"
                android:padding="18dp"
                android:src="@android:drawable/sym_action_call"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Answer"
                android:textColor="#B0B0B0"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Active Call Controls -->
    <LinearLayout
        android:id="@+id/active_call_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Row 1: Mute, Speaker, Hold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Mute -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btn_mute"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_bg_dark"
                    android:contentDescription="Mute"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_lock_silent_mode"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Mute"
                    android:textColor="#B0B0B0"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Speaker -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btn_speaker"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_bg_dark"
                    android:contentDescription="Speaker"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Speaker"
                    android:textColor="#B0B0B0"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Hold -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btn_hold"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_bg_dark"
                    android:contentDescription="Hold"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_media_pause"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Hold"
                    android:textColor="#B0B0B0"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Hangup Button -->
        <ImageButton
            android:id="@+id/btn_hangup"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/circle_bg_red"
            android:contentDescription="End Call"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_call"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="End Call"
            android:textColor="#B0B0B0"
            android:textSize="12sp" />

    </LinearLayout>

</RelativeLayout>
